# DonkeyNote STT & Summarize API — 환경변수 예시
# 실제 값을 채워 `.env`로 복사해 사용하세요 (`.env`는 커밋되지 않습니다).

# --- Naver Clova Speech (STT) ---------------------------------------------
# 도메인별 invoke URL과 시크릿 키. 둘 다 없으면 STT가 ClovaConfigError로 실패합니다.
CLOVA_SPEECH_INVOKE_URL=
CLOVA_SPEECH_API_KEY=

# --- OpenAI (요약) ---------------------------------------------------------
# 없으면 /summarize가 SummarizerError로 실패합니다.
OPENAI_API_KEY=
# 모델 오버라이드 (미설정 시 기본값 gpt-4o-mini)
OPENAI_ROUTER_MODEL=gpt-4o-mini
OPENAI_SUMMARY_MODEL=gpt-4o-mini

# --- AWS S3 감사 로그 (선택) ----------------------------------------------
# AWS_REGION + AWS_S3_LOG_BUCKET 둘 다 설정돼야 감사 로그가 활성화됩니다.
# 미설정 시 로그는 조용히 비활성화되며 서비스 흐름에는 영향 없습니다.
AWS_REGION=ap-northeast-2
AWS_S3_LOG_BUCKET=
AWS_S3_LOG_PREFIX=donkey-note
# IAM Role 사용 시 아래 두 값은 생략 가능합니다.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
